# ============================================================
#  Auth0 (login)  — copiar a .env.local y completar
# ============================================================
# Generar con: openssl rand -hex 32
AUTH0_SECRET=
AUTH0_BASE_URL=http://localhost:3000
# De Auth0 → Application → Settings ("https://" + Domain):
AUTH0_ISSUER_BASE_URL=https://TU-TENANT.us.auth0.com
AUTH0_CLIENT_ID=TU_CLIENT_ID
AUTH0_CLIENT_SECRET=TU_CLIENT_SECRET

# ============================================================
#  Supabase (base de datos) — paso 2
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY
# Legacy JWT Secret (Supabase → Settings → API → JWT Settings). SOLO server-side.
SUPABASE_JWT_SECRET=
